<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TFC_RelevosFamiliares.Pages.SplashScreen"
             Shell.NavBarIsVisible="False"
             >

    <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center" HorizontalOptions="Center">

        <Image
            Source="{AppThemeBinding Light='rf_logo.png', Dark='rf_logo_dark.png'}"
            HeightRequest="250"
            Aspect="AspectFit"
            SemanticProperties.Description="App Logo" />

        <Label Text="Cargando..."
               FontSize="16"
               HorizontalTextAlignment="Center" />

    </VerticalStackLayout>

</ContentPage>
