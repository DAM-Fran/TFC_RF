<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TFC_RelevosFamiliares.Pages.Empleado.AceptarServicios.EmpleadoServicioAceptado"
             Title="Servicio aceptado">

    <VerticalStackLayout Padding="30,0,30,40"
                         Spacing="30"
                         VerticalOptions="Center">

        <Image Source="{AppThemeBinding Light='rf_logo.png', Dark='rf_logo_dark.png'}"
               HeightRequest="150"
               Aspect="AspectFit" />

        <Label Text="¡Servicio aceptado!"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <Label Text="El servicio ha sido registrado correctamente."
               FontSize="20"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,20" />

        <Button Text="Volver al inicio"
                CornerRadius="10"
                BorderWidth="2"
                Margin="40,20"
                Clicked="OnVolverClicked" />

    </VerticalStackLayout>

</ContentPage>
