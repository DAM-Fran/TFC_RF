<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TFC_RelevosFamiliares.Pages.Empleado.AceptarServicios.EmpleadoAceptarServicio"
             Title="Servicios para aceptar">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Image
            Source="{AppThemeBinding Light='rf_logo.png', Dark='rf_logo_dark.png'}"
            HeightRequest="150"
            Aspect="AspectFit"
            Margin="0,10,0,40"
            SemanticProperties.Description="App Logo" />

        <Label Text="Servicios para aceptar"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <CollectionView x:Name="ListaServicios"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15"
                           Margin="0,10"
                           BorderColor="#CCCCCC"
                           CornerRadius="12">

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding Fecha}"
                                   FontAttributes="Bold"
                                   FontSize="18" />

                            <Label Text="{Binding Hora}"
                                   FontSize="16" />

                            <Label Text="{Binding Tipo}"
                                   FontSize="16"
                                   Opacity="0.7" />

                            <Button Text="Aceptar"
                                    BackgroundColor="#1976D2"
                                    TextColor="White"
                                    CornerRadius="10"
                                    Clicked="OnAceptarClicked" />

                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
