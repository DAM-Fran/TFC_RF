<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TFC_RelevosFamiliares.Pages.CancelacionRealizada"
             Title="Reserva cancelada">

    <VerticalStackLayout Padding="30" Spacing="25">

        <Image Source="{AppThemeBinding Light='rf_logo.png', Dark='rf_logo_dark.png'}"
               Margin="0,50,0,30"
               HeightRequest="200"
               Aspect="AspectFit" />

        <Label Text="Reserva cancelada"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <Button Text="Volver al inicio"
                CornerRadius="10"
                HeightRequest="45"
                Clicked="OnVolverClicked" />

    </VerticalStackLayout>

</ContentPage>
