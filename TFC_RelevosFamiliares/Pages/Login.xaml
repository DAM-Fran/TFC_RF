<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TFC_RelevosFamiliares.Pages.Login"
             Title="Iniciar Sesión">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="CenterAndExpand">

            <Image Source="{AppThemeBinding Light='rf_logo.png', Dark='rf_logo_dark.png'}"
                   HeightRequest="150"
                   Aspect="AspectFit" />

            <Label Text="Bienvenido a&#10;Relevos Familiares"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,20" />

            <Entry x:Name="EmailEntry"
                   Placeholder="Correo electrónico"
                   Keyboard="Email"
                   Margin="0,10,0,0" />

            <Entry x:Name="PasswordEntry"
                   Placeholder="Contraseña"
                   IsPassword="True"
                   Margin="0,10,0,0" />

            <HorizontalStackLayout Spacing="16">
                <CheckBox x:Name="RecordarmeCheck" />
                <Label Text="Recordar mi usuario"
                       VerticalTextAlignment="Center"/>
            </HorizontalStackLayout>

            <Button x:Name="LoginButton"
                    Text="Iniciar Sesión"
                    Clicked="OnLoginClicked"
                    Margin="0,20,0,0" />

            <Label Text="¿No tienes cuenta?&#10;Crear cuenta"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRegisterClicked"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
