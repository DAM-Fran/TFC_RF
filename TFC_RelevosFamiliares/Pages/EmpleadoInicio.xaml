<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TFC_RelevosFamiliares.Pages.EmpleadoInicio"
             Title="Inicio">

    <VerticalStackLayout Padding="30,0,30,40" Spacing="30" VerticalOptions="Center">

        <Label x:Name="WelcomeLabel"
               Text="¡Hola!"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <Image
            Source="{AppThemeBinding Light='rf_logo.png', Dark='rf_logo_dark.png'}"
            HeightRequest="150"
            Aspect="AspectFit"
            Margin="0,10,0,40"
            SemanticProperties.Description="App Logo" />

        <Button x:Name="BotonAceptarServicio"
                Text="Aceptar un servicio"
                Clicked="OnAceptarServicioClicked" />

        <Button x:Name="BotonMisServicios"
                Text="Mis servicios"
                Clicked="OnMisServiciosClicked" />

        <Label Text="Cerrar sesión"
               TextColor="{AppThemeBinding Light={StaticResource Negro}, Dark={StaticResource Blanco}}"
               HorizontalOptions="End"
               Margin="0,20"
               FontAttributes="Bold">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLogoutTapped"/>
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>

</ContentPage>
